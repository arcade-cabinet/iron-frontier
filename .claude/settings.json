{
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": ".claude/hooks/pre-commit-quality.sh",
            "timeout": 60
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "Edit|Write",
        "hooks": [
          {
            "type": "command",
            "command": ".claude/hooks/spec-coverage-check.sh",
            "timeout": 10
          },
          {
            "type": "command",
            "command": ".claude/hooks/no-magic-numbers.sh",
            "timeout": 10
          },
          {
            "type": "command",
            "command": ".claude/hooks/file-size-sentinel.sh",
            "timeout": 10
          },
          {
            "type": "command",
            "command": ".claude/hooks/no-math-random.sh",
            "timeout": 10
          },
          {
            "type": "command",
            "command": ".claude/hooks/no-glb-imports.sh",
            "timeout": 10
          }
        ]
      }
    ]
  }
}
