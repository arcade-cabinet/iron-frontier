{
  "name": "iron-frontier",
  "version": "0.2.0",
  "private": true,
  "main": "expo-router/entry",
  "scripts": {
    "dev": "expo start",
    "android": "expo start --android",
    "ios": "expo start --ios",
    "web": "expo start --web",
    "build": "expo export",
    "build:android": "eas build --platform android",
    "build:ios": "eas build --platform ios",
    "test": "jest",
    "test:watch": "jest --watch",
    "test:coverage": "jest --coverage",
    "test:e2e": "playwright test",
    "test:e2e:ui": "playwright test --ui",
    "test:e2e:headed": "playwright test --headed",
    "test:maestro": "maestro test .maestro/",
    "lint": "biome check .",
    "lint:fix": "biome check --write .",
    "format": "biome format --write .",
    "check": "biome check --write .",
    "typecheck": "tsc --noEmit",
    "content:gen": "pnpm exec tsx scripts/content-gen-run.ts --pipeline iron-frontier-hero --asset assets/content/characters/iron-frontier-hero --pipelines assets/content/characters/iron-frontier-hero --tasks assets/content/tasks/definitions",
    "content:gen:hero": "pnpm exec tsx scripts/content-gen-run.ts --pipeline iron-frontier-hero --asset assets/content/characters/iron-frontier-hero --pipelines assets/content/characters/iron-frontier-hero --tasks assets/content/tasks/definitions",
    "content:validate:hero": "content-gen validate assets/content/characters/iron-frontier-hero --pipeline iron-frontier-hero --pipelines assets/content/characters/iron-frontier-hero --tasks assets/content/tasks/definitions"
  },
  "dependencies": {
    "@babel/generator": "^7.29.1",
    "@babel/plugin-proposal-decorators": "^7.29.0",
    "@babel/plugin-transform-class-properties": "^7.28.6",
    "@babel/plugin-transform-class-static-block": "^7.28.6",
    "@babel/plugin-transform-export-namespace-from": "^7.27.1",
    "@babel/plugin-transform-flow-strip-types": "^7.27.1",
    "@babel/plugin-transform-private-methods": "^7.28.6",
    "@babel/plugin-transform-react-jsx": "^7.28.6",
    "@babel/template": "^7.28.6",
    "@babel/traverse": "^7.29.0",
    "@babel/types": "^7.29.0",
    "@react-three/drei": "^10.0.0",
    "@react-three/fiber": "^9.1.0",
    "@react-three/xr": "^6.0.0",
    "alea": "^1.0.1",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "connect": "^3.7.0",
    "expo": "^55.0.5",
    "expo-router": "~55.0.4",
    "expo-sqlite": "~55.0.10",
    "expo-status-bar": "~55.0.4",
    "idb-keyval": "^6.2.2",
    "metro-runtime": "^0.84.2",
    "miniplex": "^2.0.0",
    "nativewind": "^4.2.2",
    "react": "19.2.0",
    "react-dom": "19.2.0",
    "react-native": "0.83.2",
    "react-native-css-interop": "0.2.2",
    "react-native-reanimated": "^4.2.1",
    "react-native-safe-area-context": "^5.6.2",
    "react-native-screens": "~4.23.0",
    "react-native-web": "^0.21.2",
    "react-native-worklets": "0.7.2",
    "simplex-noise": "^4.0.3",
    "tailwind-merge": "^3.5.0",
    "tailwindcss-animate": "^1.0.7",
    "three": "^0.175.0",
    "tone": "^15.1.22",
    "tslib": "^2.8.1",
    "use-latest-callback": "^0.3.3",
    "yuka": "^0.7.8",
    "zod": "^4.3.6",
    "zustand": "^5.0.11"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.4.6",
    "@playwright/test": "^1.58.2",
    "@types/react": "^19.2.14",
    "@types/three": "^0.175.0",
    "autoprefixer": "^10.4.27",
    "fast-check": "^4.5.3",
    "jest": "^29.7.0",
    "jest-expo": "~55.0.0",
    "postcss": "^8.5.8",
    "tailwindcss": "^3.4.19",
    "tsx": "^4.21.0",
    "typescript": "~5.9.3"
  },
  "packageManager": "pnpm@10.20.0"
}
